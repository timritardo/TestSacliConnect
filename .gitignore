# ─────────────────────────────────────────────────────────────────────────────
# .gitignore — SacliConnect
# Only source code goes in git. Media, uploads, and dependencies are excluded.
# ─────────────────────────────────────────────────────────────────────────────

# ── User-uploaded media (never commit user content) ──────────────────────────
uploads/

# ── Composer dependencies (run `composer install` on the server instead) ─────
vendor/
composer.lock

# ── Large static media assets tracked via Git LFS ────────────────────────────
# assets/video/ and assets/audio/ are intentionally NOT ignored here.
# They are tracked by Git LFS (see .gitattributes). LFS stores the actual
# file content remotely; only lightweight pointer files live in the repo.

# ── Environment / secrets ────────────────────────────────────────────────────
.env
.env.local
.env.production

# ── Developer notes and local docs (not needed on server) ────────────────────
docs/

# ── OS and editor junk ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/

# ── PHP error logs ────────────────────────────────────────────────────────────
*.log
error_log

# ── Empty placeholder folders (git doesn't track empty dirs) ─────────────────
submissions/
